   "source": ["## Step 3 — Load Model & Setup"]
  },
  {
   "cell_type": "code",
   "metadata": {},
   "source": [
    "import pickle\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "from sklearn.preprocessing import StandardScaler\n",
    "import gradio as gr\n",
    "\n",
    "# Load the trained Random Forest model\n",
    "with open('random_forest.pkl', 'rb') as f:\n",
    "    model = pickle.load(f)\n",
    "\n",
    "# Load X_train just to get the exact column names and order\n",
    "# Our input must match the exact same feature structure the model was trained on\n",
    "X_train = pd.read_csv('X_train.csv')\n",
    "feature_columns = X_train.columns.tolist()\n",
    "\n",
    "# Re-fit a scaler on X_train so we can scale new inputs the same way\n",
    "# (Same scaler logic as Notebook 1 — fit on training data)\n",
    "scaler = StandardScaler()\n",
    "scaler.fit(X_train)\n",
    "\n",
    "print(f'Model loaded ✅')\n",
    "print(f'Expects {len(feature_columns)} features')"
   ],
   "execution_count": null,
   "outputs": []
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": ["## Step 4 — Define the Prediction Function"]
  },
  {
   "cell_type": "code",
   "metadata": {},
   "source": [
    "def predict_student(age, studytime, failures, absences, goout, Walc, Dalc,\n",
    "                    health, Medu, Fedu, traveltime, famrel, freetime,\n",
    "                    school_MS, sex_M, address_U, famsize_LE3, Pstatus_T,\n",
    "                    Mjob_health, Mjob_other, Mjob_services, Mjob_teacher,\n",
    "                    Fjob_health, Fjob_other, Fjob_services, Fjob_teacher,\n",
    "                    reason_home, reason_other, reason_reputation,\n",
    "                    guardian_mother, guardian_other,\n",
    "                    schoolsup_yes, famsup_yes, paid_yes, activities_yes,\n",
    "                    nursery_yes, higher_yes, internet_yes, romantic_yes):\n",
    "\n",
    "    # Pack all inputs into a dictionary matching the training feature names exactly\n",
    "    input_dict = {\n",
    "        'age': age, 'Medu': Medu, 'Fedu': Fedu, 'traveltime': traveltime,\n",
    "        'studytime': studytime, 'failures': failures, 'famrel': famrel,\n",
    "        'freetime': freetime, 'goout': goout, 'Dalc': Dalc, 'Walc': Walc,\n",
    "        'health': health, 'absences': absences,\n",
    "        'school_MS': int(school_MS), 'sex_M': int(sex_M),\n",
    "        'address_U': int(address_U), 'famsize_LE3': int(famsize_LE3),\n",
    "        'Pstatus_T': int(Pstatus_T), 'Mjob_health': int(Mjob_health),\n",
    "        'Mjob_other': int(Mjob_other), 'Mjob_services': int(Mjob_services),\n",
    "        'Mjob_teacher': int(Mjob_teacher), 'Fjob_health': int(Fjob_health),\n",
    "        'Fjob_other': int(Fjob_other), 'Fjob_services': int(Fjob_services),\n",
    "        'Fjob_teacher': int(Fjob_teacher), 'reason_home': int(reason_home),\n",
    "        'reason_other': int(reason_other), 'reason_reputation': int(reason_reputation),\n",
    "        'guardian_mother': int(guardian_mother), 'guardian_other': int(guardian_other),\n",
    "        'schoolsup_yes': int(schoolsup_yes), 'famsup_yes': int(famsup_yes),\n",
    "        'paid_yes': int(paid_yes), 'activities_yes': int(activities_yes),\n",
    "        'nursery_yes': int(nursery_yes), 'higher_yes': int(higher_yes),\n",
    "        'internet_yes': int(internet_yes), 'romantic_yes': int(romantic_yes)\n",
    "    }\n",
    "\n",
    "    # Convert to DataFrame with correct column order\n",
    "    input_df = pd.DataFrame([input_dict])[feature_columns]\n",
    "\n",
    "    # Scale the input using the same scaler fitted on training data\n",
    "    input_scaled = scaler.transform(input_df)\n",
    "\n",
    "    # Get prediction and probability\n",
    "    prediction = model.predict(input_scaled)[0]\n",
    "    probability = model.predict_proba(input_scaled)[0]\n",
    "\n",
    "    fail_prob = probability[0] * 100\n",
    "    pass_prob = probability[1] * 100\n",
    "\n",
    "    if prediction == 1:\n",
    "        result = f'✅ PASS\\n\\nConfidence: {pass_prob:.1f}%\\nFail probability: {fail_prob:.1f}%'\n",
    "    else:\n",
    "        result = f'❌ FAIL\\n\\nConfidence: {fail_prob:.1f}%\\nPass probability: {pass_prob:.1f}%'\n",
    "\n",
    "    return result\n",
    "\n",
    "print('Prediction function defined ✅')"
   ],
   "execution_count": null,
   "outputs": []
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": ["## Step 5 — Launch the Web App"]
  },
  {
   "cell_type": "code",
   "metadata": {},
   "source": [
    "# Build the Gradio interface\n",
    "# We group inputs into tabs so it's not overwhelming\n",
    "\n",
    "with gr.Blocks(title='Student Pass/Fail Predictor', theme=gr.themes.Soft()) as app:\n",
    "\n",
    "    gr.Markdown('# 🎓 Student Pass/Fail Predictor')\n",
    "    gr.Markdown('Fill in the student details below and click **Predict** to see if they will pass or fail.')\n",
    "    gr.Markdown('> Model: Random Forest | Dataset: UCI Student Performance')\n",
    "\n",
    "    with gr.Tabs():\n",
    "\n",
    "        # --- TAB 1: The most important features (from SHAP analysis) ---\n",
    "        with gr.Tab('⭐ Key Features'):\n",
    "            gr.Markdown('### These are the features that matter most (from SHAP analysis)')\n",
    "            with gr.Row():\n",
    "                failures   = gr.Slider(0, 4, value=0, step=1, label='Past Failures (0=none, 4=many)')\n",
    "                absences   = gr.Slider(0, 93, value=5, step=1, label='Number of Absences')\n",
    "            with gr.Row():\n",
    "                goout      = gr.Slider(1, 5, value=3, step=1, label='Going Out with Friends (1=low, 5=high)')\n",
    "                studytime  = gr.Slider(1, 4, value=2, step=1, label='Weekly Study Time (1=<2h, 4=>10h)')\n",
    "            with gr.Row():\n",
    "                Walc       = gr.Slider(1, 5, value=2, step=1, label='Weekend Alcohol Use (1=low, 5=high)')\n",
    "                Dalc       = gr.Slider(1, 5, value=1, step=1, label='Weekday Alcohol Use (1=low, 5=high)')\n",
    "\n",
    "        # --- TAB 2: Student background ---\n",
    "        with gr.Tab('👤 Student Info'):\n",
    "            with gr.Row():\n",
    "                age        = gr.Slider(15, 22, value=17, step=1, label='Age')\n",
    "                health     = gr.Slider(1, 5, value=3, step=1, label='Health Status (1=bad, 5=excellent)')\n",
    "            with gr.Row():\n",
    "                freetime   = gr.Slider(1, 5, value=3, step=1, label='Free Time After School (1=low, 5=high)')\n",
    "                traveltime = gr.Slider(1, 4, value=1, step=1, label='Travel Time to School (1=<15min, 4=>1hr)')\n",
    "            with gr.Row():\n",
    "                sex_M      = gr.Checkbox(label='Male', value=True)\n",
    "                address_U  = gr.Checkbox(label='Urban Address', value=True)\n",
    "                romantic_yes = gr.Checkbox(label='In a Romantic Relationship', value=False)\n",
    "                higher_yes = gr.Checkbox(label='Wants Higher Education', value=True)\n",
    "                internet_yes = gr.Checkbox(label='Has Internet at Home', value=True)\n",
    "\n",
    "        # --- TAB 3: Family background ---\n",
    "        with gr.Tab('👨‍👩‍👦 Family'):\n",
    "            with gr.Row():\n",
    "                Medu       = gr.Slider(0, 4, value=2, step=1, label=\"Mother's Education (0=none, 4=higher ed)\")\n",
    "                Fedu       = gr.Slider(0, 4, value=2, step=1, label=\"Father's Education (0=none, 4=higher ed)\")\n",
    "            with gr.Row():\n",
    "                famrel     = gr.Slider(1, 5, value=4, step=1, label='Family Relationship Quality (1=bad, 5=excellent)')\n",
    "                famsize_LE3 = gr.Checkbox(label='Family Size ≤ 3', value=False)\n",
    "                Pstatus_T  = gr.Checkbox(label='Parents Living Together', value=True)\n",
    "                famsup_yes = gr.Checkbox(label='Family Educational Support', value=True)\n",
    "            with gr.Row():\n",
    "                guardian_mother = gr.Checkbox(label='Guardian: Mother', value=True)\n",
    "                guardian_other  = gr.Checkbox(label='Guardian: Other', value=False)\n",
    "            gr.Markdown('**Mother Job:**')\n",
    "            with gr.Row():\n",
    "                Mjob_health   = gr.Checkbox(label='Health', value=False)\n",
    "                Mjob_other    = gr.Checkbox(label='Other', value=True)\n",
    "                Mjob_services = gr.Checkbox(label='Services', value=False)\n",
    "                Mjob_teacher  = gr.Checkbox(label='Teacher', value=False)\n",
    "            gr.Markdown('**Father Job:**')\n",
    "            with gr.Row():\n",
    "                Fjob_health   = gr.Checkbox(label='Health', value=False)\n",
    "                Fjob_other    = gr.Checkbox(label='Other', value=True)\n",
    "                Fjob_services = gr.Checkbox(label='Services', value=False)\n",
    "                Fjob_teacher  = gr.Checkbox(label='Teacher', value=False)\n",
    "\n",
    "        # --- TAB 4: School related ---\n",
    "        with gr.Tab('🏫 School'):\n",
    "            with gr.Row():\n",
    "                school_MS     = gr.Checkbox(label='School: Mousinho da Silveira (MS)', value=False)\n",
    "                schoolsup_yes = gr.Checkbox(label='Extra School Support', value=False)\n",
    "                paid_yes      = gr.Checkbox(label='Extra Paid Classes', value=False)\n",
    "                activities_yes = gr.Checkbox(label='Extracurricular Activities', value=False)\n",
    "                nursery_yes   = gr.Checkbox(label='Attended Nursery School', value=True)\n",
    "            gr.Markdown('**Reason for Choosing This School:**')\n",
    "            with gr.Row():\n",
    "                reason_home       = gr.Checkbox(label='Close to Home', value=False)\n",
    "                reason_other      = gr.Checkbox(label='Other Reason', value=False)\n",
    "                reason_reputation = gr.Checkbox(label='School Reputation', value=True)\n",
    "\n",
    "    # Predict button and output\n",
    "    predict_btn = gr.Button('🔮 Predict', variant='primary', size='lg')\n",
    "    output = gr.Textbox(label='Prediction Result', lines=4, interactive=False)\n",
    "\n",
    "    # Wire the button to the prediction function\n",
    "    predict_btn.click(\n",
    "        fn=predict_student,\n",
    "        inputs=[\n",
    "            age, studytime, failures, absences, goout, Walc, Dalc, health,\n",
    "            Medu, Fedu, traveltime, famrel, freetime,\n",
    "            school_MS, sex_M, address_U, famsize_LE3, Pstatus_T,\n",
    "            Mjob_health, Mjob_other, Mjob_services, Mjob_teacher,\n",
    "            Fjob_health, Fjob_other, Fjob_services, Fjob_teacher,\n",
    "            reason_home, reason_other, reason_reputation,\n",
    "            guardian_mother, guardian_other,\n",
    "            schoolsup_yes, famsup_yes, paid_yes, activities_yes,\n",
    "            nursery_yes, higher_yes, internet_yes, romantic_yes\n",
    "        ],\n",
    "        outputs=output\n",
    "    )\n",
    "\n",
    "    gr.Markdown('---')\n",
    "    gr.Markdown('*Built with Random Forest | UCI Student Performance Dataset | PES University ML Project*')\n",
    "\n",
    "# Launch — share=True gives a public link valid for 72 hours\n",
    "# Great for showing during presentation without needing everyone to run Colab\n",
    "app.launch(share=True)"
   ],
